# Copy to `server/.env` (gitignored). Do not commit real secrets.
# JWT secret must stay server-only — never in client/.env or REACT_APP_*.

SUPABASE_JWT_SECRET=
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=

# Optional: Jira project for “Create DOC ticket” (defaults to DOC).
# RELEASENOTES_DOC_PROJECT_KEY=DOC
# Optional: comma-separated link type names or numeric ids (from GET /rest/api/3/issueLinkType) for DOC ↔ reference issue.
# The app also auto-picks types whose name/inward/outward matches “relat…”. Example:
# RELEASENOTES_DOC_RELATES_LINK_TYPE=10000,Relates
