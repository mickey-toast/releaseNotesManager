# Copy to `.env` in the repo root (optional). The server also loads `server/.env`.
# Never put SUPABASE_JWT_SECRET in `client/.env` or any REACT_APP_* variable.

# Supabase (server only) — see Supabase → Project Settings → API
SUPABASE_JWT_SECRET=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: default allowed sign-in email domain (see server/authMiddleware.js)
# ALLOWED_EMAIL_DOMAIN=@toasttab.com
