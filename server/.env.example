# Copy to `server/.env` (gitignored). Do not commit real secrets.
# JWT secret must stay server-only — never in client/.env or REACT_APP_*.

SUPABASE_JWT_SECRET=
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=

# Optional: Jira project for “Create DOC ticket” (defaults to DOC).
# RELEASENOTES_DOC_PROJECT_KEY=DOC
# Optional: comma-separated link type names to try when linking DOC ↔ reference issue (default: Relates, Relates to, …).
# RELEASENOTES_DOC_RELATES_LINK_TYPE=Relates,Relates to
