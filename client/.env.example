# Supabase (browser-safe keys only). Required if the server has SUPABASE_JWT_SECRET set.
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: comma-separated emails that see Settings → Admin (defaults in client/src/settingsAdminAccess.js).
# REACT_APP_SETTINGS_SUPER_ADMIN_EMAILS=you@toasttab.com,colleague@toasttab.com
